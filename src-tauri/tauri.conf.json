{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskPlayer",
  "version": "0.9.5",
  "identifier": "com.taskplayer.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:frontend",
    "beforeBuildCommand": "pnpm run build:frontend",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["taskplayer"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4RDUyQTdCMUJDN0ZDODMKUldTRC9NY2JleXJWS0FUeG5lNVpPaDVrWU9ZdWFnRkVBbTRnTGRwb20yVTBCOS9OU28zSGlEaE8K",
      "endpoints": [
        "https://github.com/isubham/homebrew-taskplayer/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TaskPlayer",
        "width": 1280,
        "height": 840,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "trafficLightPosition": { "x": 20, "y": 36 },
        "backgroundColor": "#121212",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
