{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskPlayer",
  "version": "0.1.0",
  "identifier": "com.taskplayer.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["taskplayer"]
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TaskPlayer",
        "width": 1040,
        "height": 700,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#121212",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
