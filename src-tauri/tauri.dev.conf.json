{
  "productName": "TaskPlayer Dev",
  "identifier": "com.taskplayer.desktop.dev",
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["taskplayer-dev"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TaskPlayer (Dev)",
        "width": 1280,
        "height": 840,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "trafficLightPosition": { "x": 20, "y": 36 },
        "backgroundColor": "#121212",
        "dragDropEnabled": false
      }
    ]
  }
}
